# ---- AI Co-Scientist configuration (copy to .env and fill in) ----

# AWS region with Bedrock Claude model access enabled
AWS_REGION=us-west-2

# LLM provider: "bedrock" (real) or "mock" (offline, deterministic, no AWS needed)
COSCIENTIST_LLM_PROVIDER=bedrock

# Bedrock model ids (inference profile ids). Override per your enabled models.
COSCIENTIST_MODEL_STRONG=us.anthropic.claude-sonnet-4-5-20250929-v1:0
COSCIENTIST_MODEL_FAST=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Protein scorer: "heuristic" (no deps), "esm" (needs torch+transformers),
# or "predictor" (your fine-tuned checkpoint)
COSCIENTIST_SCORER=heuristic

# Path to a fine-tuned predictor checkpoint (when COSCIENTIST_SCORER=predictor)
COSCIENTIST_PREDICTOR_CKPT=

# ESM2 model name for the esm scorer (small = CPU-friendly)
COSCIENTIST_ESM_MODEL=facebook/esm2_t12_35M_UR50D
